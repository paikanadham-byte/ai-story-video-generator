# ─── LLM ───
# Provider: "openrouter" (recommended, has free models) or "openai"
LLM_PROVIDER=openrouter
LLM_API_KEY=your_openrouter_api_key_here
LLM_MODEL=google/gemini-2.0-flash-exp:free
# LLM_BASE_URL=https://openrouter.ai/api/v1

# Only needed if using OpenAI TTS (TTS_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here

# ─── Media APIs ───
PEXELS_API_KEY=your_pexels_api_key_here
PIXABAY_API_KEY=your_pixabay_api_key_here
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# ─── TTS ───
# "edge" = FREE (Microsoft Edge TTS, no API key needed)
# "openai" = Paid (high quality, uses OPENAI_API_KEY above)
TTS_PROVIDER=edge
# Default voice (ignored when voiceStyle is selected in UI)
TTS_DEFAULT_VOICE=en-US-AndrewNeural

# ─── Server ───
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── FFmpeg ───
# Leave blank to use system ffmpeg
FFMPEG_PATH=
FFPROBE_PATH=

# ─── Output ───
OUTPUT_DIR=./output
MAX_CONCURRENT_RENDERS=2
